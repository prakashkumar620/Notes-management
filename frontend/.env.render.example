# Frontend Environment Variables - Example for Render Deployment

# ============================================
# API CONFIGURATION
# ============================================

# Backend API URL - Point to your Render backend
# Example: https://notes-backend-abc123.onrender.com
REACT_APP_API_URL=https://notes-backend-abc123.onrender.com

# ============================================
# GOOGLE OAUTH
# ============================================

# Google Client ID (same as backend)
# Get from: https://console.cloud.google.com
# Must be the same CLIENT ID used in backend
REACT_APP_GOOGLE_CLIENT_ID=1234567890-abcdefghijklmnopqrstuvwxyz123456.apps.googleusercontent.com

# ============================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================

# Google Analytics Tracking ID (optional)
# REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry Error Tracking (optional)
# REACT_APP_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# OPTIONAL: FEATURE FLAGS
# ============================================

# Enable debugging tools in production
REACT_APP_DEBUG=false

# Enable experimental features
REACT_APP_EXPERIMENTAL_FEATURES=false

# ============================================
# OPTIONAL: APP CONFIGURATION
# ============================================

# Application name (shown in browser title)
REACT_APP_NAME=Notes Management System

# API timeout in milliseconds
REACT_APP_API_TIMEOUT=30000

# ============================================
# NOTES FOR RENDER DEPLOYMENT
# ============================================

# 1. REACT_APP_API_URL:
#    - Must be HTTPS (not HTTP)
#    - Should be your Render backend service URL
#    - Example: https://notes-backend-xyz.onrender.com
#    - Make sure backend CORS_ORIGIN matches this frontend URL

# 2. REACT_APP_GOOGLE_CLIENT_ID:
#    - Get from Google Cloud Console
#    - Must match the ID used in backend
#    - Add this URL to Google OAuth authorized URIs:
#      * http://localhost:3000 (local development)
#      * https://notes-frontend-abc123.onrender.com (production)

# 3. For Render deployment:
#    - Add all REACT_APP_* variables to Render environment
#    - Render will rebuild frontend when variables change
#    - Restart is automatic
#    - Do NOT commit this file to Git (use .env.example for team)

# 4. Build time vs Runtime:
#    - React env vars are baked into build at compile time
#    - To change them, trigger a new build on Render
#    - Frontend redeploys automatically when you update env vars in Render

# ============================================
# IMPORTANT SECURITY NOTE
# ============================================

# Never put sensitive secrets in frontend .env files!
# They get embedded in JavaScript bundle and visible to anyone.
#
# Safe to put in frontend env:
# ✓ Public API URLs
# ✓ Google Client ID (it's public anyway)
# ✓ Feature flags
# ✓ App configuration
#
# NEVER put in frontend env:
# ✗ API keys (use backend proxy instead)
# ✗ Database credentials
# ✗ JWT secrets
# ✗ OAuth client secrets
