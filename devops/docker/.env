# Google OAuth Credentials
# Set these environment variables with your actual credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# MongoDB Configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=your_secure_password_here

# Backend Configuration
JWT_SECRET=your_jwt_secret_here
NODE_ENV=production
PORT=5000
CORS_ORIGIN=http://localhost:3000

# Admin and Teacher Configuration
ADMIN_EMAIL=your_admin_email@example.com
TEACHER_EMAILS=your_teacher_email@example.com

# Database URI
MONGODB_URI=mongodb://admin:your_password@mongodb:27017/notes-management?authSource=admin

# Frontend Configuration
REACT_APP_GOOGLE_CLIENT_ID=your_react_google_client_id_here
REACT_APP_API_BASE_URL=http://localhost:5000
