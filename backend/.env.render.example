# Backend Environment Variables - Example for Render Deployment

# ============================================
# SERVER CONFIGURATION
# ============================================

# Port - Render will set this automatically
PORT=5000

# Environment mode
NODE_ENV=production

# ============================================
# DATABASE - MongoDB Atlas
# ============================================

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://ayush20042006_db_user:WE7orkpvA4FxGCoQ@hotel1.foze29j.mongodb.net/hotel-chandra-bharti

# ============================================
# GOOGLE OAUTH
# ============================================

# Get these from: https://console.cloud.google.com
# Create OAuth 2.0 credentials (Web application)

# Your Google Client ID
GOOGLE_CLIENT_ID=1234567890-abcdefghijklmnopqrstuvwxyz123456.apps.googleusercontent.com

# Your Google Client Secret
GOOGLE_CLIENT_SECRET=GOCSPX-abcdefghijklmnopqrstuvwxyz

# ============================================
# JWT AUTHENTICATION
# ============================================

# Secret key for JWT tokens
# Generate a strong random string (min 32 characters)
# Command to generate: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_characters_long

# ============================================
# CORS SETTINGS
# ============================================

# Frontend URL for CORS (will be your Render frontend URL)
# Example: https://notes-frontend-abc123.onrender.com
CORS_ORIGIN=https://notes-frontend-abc123.onrender.com

# ============================================
# OPTIONAL: EMAIL CONFIGURATION
# ============================================

# If you want to enable email notifications
# Using Gmail App Password (not your actual Gmail password)

# Your email address
SMTP_EMAIL=your_email@gmail.com

# Gmail App Password (https://myaccount.google.com/apppasswords)
SMTP_PASSWORD=your_app_specific_password

# ============================================
# OPTIONAL: FILE UPLOAD
# ============================================

# Maximum file upload size (in MB)
MAX_FILE_SIZE=300

# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ============================================
# OPTIONAL: LOGGING & DEBUGGING
# ============================================

# Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Enable detailed error logging
DEBUG=false

# ============================================
# SECURITY
# ============================================

# Session timeout (in minutes)
SESSION_TIMEOUT=60

# Password reset token expiration (in hours)
PASSWORD_RESET_EXPIRY=24

# ============================================
# NOTES FOR RENDER DEPLOYMENT
# ============================================

# 1. MONGODB_URI: 
#    - Create free cluster at mongodb.com/cloud/atlas
#    - Create database user
#    - Copy connection string and replace password
#    - Format: mongodb+srv://username:password@cluster.mongodb.net/dbname

# 2. GOOGLE OAUTH:
#    - Create project in Google Cloud Console
#    - Create OAuth 2.0 credentials
#    - Add authorized URIs:
#      * http://localhost:5000/api/auth/callback (local)
#      * https://your-backend-render-url.onrender.com/api/auth/callback (production)

# 3. JWT_SECRET:
#    - Generate secure random string
#    - Must be at least 32 characters
#    - Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# 4. CORS_ORIGIN:
#    - Must match your Render frontend URL exactly
#    - Without trailing slash
#    - Example: https://notes-frontend-xyz.onrender.com

# 5. For Render deployment:
#    - Add all variables to Render service environment
#    - Render will automatically restart service when variables change
#    - Do NOT commit this file to Git (use .env.example for team)
